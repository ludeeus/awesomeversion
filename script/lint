#!/bin/sh

# script/lint: Run linting tools and apply formatting

set -e

cd "$(dirname "$0")/.."

echo "==> Running linting tools..."

echo "==> Running ruff check..."
uv run --dev ruff check --fix awesomeversion tests benchmarks

echo "==> Running ruff format..."
uv run --dev ruff format awesomeversion tests benchmarks

echo "==> Running mypy..."
uv run --dev mypy --strict awesomeversion tests benchmarks

echo "==> Running pylint..."
uv run --dev pylint awesomeversion tests benchmarks

echo "==> Linting completed!"
